# ============================================================
# Environment variables template.
# Copy this file to .env (which is gitignored) and fill in real
# values. Never commit .env or any real secret.
# ============================================================

# --- Weights & Biases (experiment tracking) ---
WANDB_API_KEY=
WANDB_PROJECT=multi-model-ids-comparison

# --- MLflow tracking server ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Kaggle API (optional dataset-download route) ---
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Reproducibility ---
GLOBAL_SEED=42

# --- Notifications (optional) ---
SUPERVISOR_EMAIL=drozita@uoguelph.ca
